{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ElevenLabs": {
    "ApiKey": "<YOUR_ELEVENLABS_API_KEY>",
    "VoiceId": "<YOUR_ELEVENLABS_VOICE_ID>"
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=<YOUR_DB_HOST>;Port=5432;Database=<YOUR_DB_NAME>;Username=<YOUR_DB_USER>;Password=<YOUR_DB_PASSWORD>;"
  },
  "GCP": {
    "CredentialsPath": "<YOUR_GCP_SERVICE_ACCOUNT>.json"
  },
  "OpenAI": {
    "ApiKey": "<YOUR_OPENAI_API_KEY>",
    "BaseUrl": "https://api.openai.com/v1",
    "Model": "gpt-3.5-turbo"
  },
  "AllowedHosts": "*",
  "Gemini": {
    "ApiKey": "<YOUR_GEMINI_API_KEY>",
    "ModelId": "gemini-2.5-flash"
  },
  "Jwt": {
    "Key": "<YOUR_JWT_SECRET_KEY_MIN_32_CHARS>",
    "Issuer": "SmartBearServer",
    "Audience": "SmartBearMobileApp",
    "ExpireMinutes": 1440
  },
  "Google": {
    "ClientIds": [
      "<YOUR_GOOGLE_OAUTH_CLIENT_ID_1>.apps.googleusercontent.com",
      "<YOUR_GOOGLE_OAUTH_CLIENT_ID_2>.apps.googleusercontent.com"
    ],
    "ClientSecret": "<YOUR_GOOGLE_CLIENT_SECRET>"
  },
  "PayOS": {
    "Environment": {
      "PAYOS_CLIENT_ID": "<YOUR_PAYOS_CLIENT_ID>",
      "PAYOS_API_KEY": "<YOUR_PAYOS_API_KEY>",
      "PAYOS_CHECKSUM_KEY": "<YOUR_PAYOS_CHECKSUM_KEY>"
    },
    "Urls": {
      "CancelUrl": "https://your-domain.com/cancel",
      "SuccessUrl": "https://your-domain.com/success"
    }
  },
  "GCS": {
    "StoryBucket": "<YOUR_GCS_STORY_BUCKET>",
    "MusicBucket": "<YOUR_GCS_MUSIC_BUCKET>",
    "DemoVoiceBucket": "<YOUR_GCS_DEMO_VOICE_BUCKET>",
    "SignedUrlMinutes": "30"
  },
  "AppConfiguration": {
    "BridgeBaseUrl": "http://localhost:8000",
    "Subscription": {
      "ProTrialDays": 30,
      "InitialSmartCandies": 50,
      "InitialVoiceHoneys": 20
    }
  },
  "Redis": {
    "Configuration": "127.0.0.1:6379",
    "InstanceName": "SmartBear:"
  }
}
